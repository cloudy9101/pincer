{
  "name": "pincer-gateway",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler d1 migrations apply DB --remote && wrangler deploy",
    "migrate:local": "wrangler d1 migrations apply DB --local",
    "migrate:remote": "wrangler d1 migrations apply DB --remote",
    "typecheck": "tsc --noEmit",
    "test:e2e": "bunx playwright test",
    "test:e2e:ui": "bunx playwright test --ui",
    "test:e2e:codegen": "bunx playwright codegen"
  },
  "dependencies": {
    "@ai-sdk/mcp": "^1.0.21",
    "ai": "^6.0.85",
    "croner": "^10.0.1",
    "workers-ai-provider": "^3.1.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260213.0",
    "@playwright/test": "^1.58.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.65.0"
  }
}
