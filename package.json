{
  "name": "pincer-gateway",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "migrate:local": "wrangler d1 execute pincer-db --local --file=migrations/0001_initial.sql",
    "migrate:remote": "wrangler d1 execute pincer-db --remote --file=migrations/0001_initial.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.43",
    "@ai-sdk/google": "^3.0.29",
    "@ai-sdk/openai": "^3.0.28",
    "@anthropic-ai/sdk": "^0.74.0",
    "ai": "^6.0.85"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260213.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.65.0"
  }
}
